{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p \"${PROJECT_DIR:-.}/logs\" && echo \"[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] STOP audience-management: reason=$STOP_REASON\" >> \"${PROJECT_DIR:-.}/logs/stop-failures.log\""
          }
        ]
      }
    ]
  }
}
